# ─── Data Source (pick one) ────────────────────────────────────────────────

# Option A: single file — local dev / quick testing
COVERAGE_FILE_PATH=~/Downloads/index.json

# Option B: directory of per-build files named coverage_{tag}.json
# Use this in deployment when Jenkins mounts artifacts into the container.
# Uncomment and set when deploying:
# COVERAGE_DIR=/mnt/coverage

# ─── Auth ──────────────────────────────────────────────────────────────────
# Required when MCP_TRANSPORT=sse. Ignored for stdio.
# Store only the SHA-256 hash — never the raw key.
# Generate both with:  python3 keygen.py
MCP_API_KEY_HASH=replace-with-sha256-hash-from-keygen

# ─── Transport ─────────────────────────────────────────────────────────────
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8080
