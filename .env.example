# MongoDB
MONGO_USER=admin
MONGO_PASSWORD=changeme
MONGO_DB=coverage

# Sync service (HTTP trigger)
SYNC_API_KEY_HASH=   # SHA-256 hex of raw key — run: python3 sync/keygen.py
SYNC_PORT=8888       # port Jenkins POSTs to

# MCP server
MCP_API_KEY_HASH=    # separate key — run: python3 coverage-mcp-server/keygen.py
MCP_PORT=9090
